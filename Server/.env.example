# ── Network ──────────────────────────────────────────────
# IP address the server binds to.
# Use 0.0.0.0 to accept connections on all interfaces,
# or set to the robot's Ethernet IP when testing over cable.
SERVER_HOST=0.0.0.0

# Port the server listens on.
SERVER_PORT=8000

# ── Camera ───────────────────────────────────────────────
# Camera device index (0 = first camera).
CAMERA_SOURCE=0

# Frame rate for the camera stream.
CAMERA_FRAMERATE=30

# Resolution for the camera stream (widthxheight).
CAMERA_RESOLUTION=1280x720

# ── Recording ────────────────────────────────────────────
# Set to true to save camera recordings to the recordings/ folder.
# Default is false to avoid filling disk during testing sessions.
ENABLE_RECORDING=false
